# ==============================================================================
# 基于多模态大模型的智能视频剪辑 Agent - 环境变量配置模板
# ==============================================================================
# 使用方式:
#   cp .env.example .env
#   然后编辑 .env 填入你自己的密钥和配置
# ==============================================================================

# ---------------------------------------------------------------------------
# AgnesAPI — 多模态大模型（免费，OpenAI 兼容 | https://platform.agnes-ai.com/）
# ---------------------------------------------------------------------------
AGNES_API_KEY=your_api_key_here
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash

# ---------------------------------------------------------------------------
# 数据库 - PostgreSQL (异步 / 同步)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://vagent:vagent_secret@localhost:5432/vagent
DATABASE_URL_SYNC=postgresql+psycopg2://vagent:vagent_secret@localhost:5432/vagent

# ---------------------------------------------------------------------------
# Redis - 缓存 / Celery Broker / Celery Result Backend
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# Qdrant - 向量数据库
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ---------------------------------------------------------------------------
# 输出目录
# ---------------------------------------------------------------------------
OUTPUT_DIR=./output

# ---------------------------------------------------------------------------
# 中文字体路径 (用于字幕渲染)
# ---------------------------------------------------------------------------
# Windows 常见路径:
FONT_PATH=C:/Windows/Fonts/simhei.ttf
# Linux / Docker 常见路径:
# FONT_PATH=/usr/share/fonts/NotoSansSC-Regular.ttf
